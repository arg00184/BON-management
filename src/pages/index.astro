---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
	{
		kicker: 'Traffic',
		title: 'Marketing en redes sociales',
		text: 'Contenido, calendario y distribucion en plataformas clave para atraer una audiencia que ya llega preparada para convertir.',
	},
	{
		kicker: 'Strategy',
		title: 'Optimizacion de estrategia',
		text: 'Revision de precios, embudos, PPV, retencion y comportamiento de fans para mejorar ingresos con datos reales.',
	},
	{
		kicker: 'Brand',
		title: 'Desarrollo de branding',
		text: 'Posicionamiento, tono, imagen y narrativa para que la creadora tenga una marca reconocible, deseable y consistente.',
	},
	{
		kicker: 'Scale',
		title: 'Sistemas de escalado',
		text: 'Testing de hooks, lectura de senales, expansion multi-cuenta y rutinas semanales para multiplicar lo que funciona.',
	},
	{
		kicker: 'Chat',
		title: 'Chatting en OnlyFans',
		text: 'Conversaciones, upsells, renovaciones y retencion gestionadas con protocolos que protegen la marca personal.',
	},
	{
		kicker: 'Ops',
		title: 'Management integral',
		text: 'Planificacion, reporting, equipo operativo y seguimiento de KPIs para que la creadora pueda centrarse en crear.',
	},
];

const pillars = [
	{
		value: '01',
		title: 'Marca con criterio',
		text: 'La creadora no se ve como una cuenta mas. Tiene una identidad clara, premium y facil de reconocer.',
	},
	{
		value: '02',
		title: 'Crecimiento medible',
		text: 'Cada decision se conecta con trafico, conversion, retencion y valor del fan, no con intuiciones sueltas.',
	},
	{
		value: '03',
		title: 'Operacion diaria',
		text: 'Marketing, chatting y reporting trabajan coordinados para que el negocio avance todos los dias.',
	},
];

const steps = [
	'Auditoria inicial de marca, contenido, trafico y monetizacion.',
	'Direccion visual, oferta, precios y calendario de crecimiento.',
	'Ejecucion de marketing, chatting, optimizacion y reporting.',
	'Escalado con pruebas semanales y decisiones basadas en datos.',
];
---

<BaseLayout>
	<main class="overflow-hidden">
		<header class="fixed left-0 right-0 top-0 z-50 border-b border-bon-line/80 bg-white/86 backdrop-blur-xl">
			<div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 sm:px-8">
				<a class="focus-ring rounded-sm text-sm font-bold uppercase tracking-[0.16em] text-bon-950" href="#inicio">
					BON
				</a>
				<nav class="hidden items-center gap-8 text-sm font-medium text-bon-950/64 md:flex" aria-label="Principal">
					<a class="transition hover:text-bon-blue" href="#sistema">Sistema</a>
					<a class="transition hover:text-bon-blue" href="#servicios">Servicios</a>
					<a class="transition hover:text-bon-blue" href="#proceso">Proceso</a>
				</nav>
				<a
					class="focus-ring rounded-full bg-bon-blue px-5 py-2 text-sm font-semibold text-white shadow-lg shadow-bon-blue/20 transition hover:bg-bon-pink"
					href="#aplicar"
				>
					Aplicar
				</a>
			</div>
		</header>

		<section id="inicio" class="soft-grid relative min-h-screen px-5 pb-20 pt-32 sm:px-8 lg:pt-36">
			<div class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-[0.98fr_1.02fr]">
				<div data-reveal>
					<p class="mb-5 inline-flex rounded-full border border-bon-blue/18 bg-white px-4 py-2 text-sm font-semibold text-bon-blue shadow-sm">
						OnlyFans Management para creadoras que quieren crecer en serio
					</p>
					<h1 class="max-w-4xl text-balance text-4xl font-semibold leading-[1.05] text-bon-950 sm:text-6xl sm:leading-[1.02] lg:text-7xl">
						Una agencia que convierte tu marca personal en un negocio escalable.
					</h1>
					<p class="mt-7 max-w-2xl text-lg leading-8 text-bon-950/68">
						Marketing, branding, viralidad, chatting y management coordinados para que la creadora gane claridad, tiempo y una estructura profesional detras de su contenido.
					</p>
					<div class="mt-9 flex flex-col gap-3 sm:flex-row">
						<a
							class="focus-ring rounded-full bg-bon-blue px-6 py-3 text-center text-sm font-semibold text-white shadow-xl shadow-bon-blue/22 transition hover:bg-bon-pink"
							href="#aplicar"
						>
							Solicitar auditoria
						</a>
						<a
							class="focus-ring rounded-full border border-bon-line bg-white px-6 py-3 text-center text-sm font-semibold text-bon-950 transition hover:border-bon-blue hover:text-bon-blue"
							href="#servicios"
						>
							Ver servicios
						</a>
					</div>
					<div class="mt-10 grid max-w-xl grid-cols-1 gap-3 sm:grid-cols-3">
						<div class="rounded-[8px] bg-white/76 p-4 shadow-sm ring-1 ring-bon-line/80">
							<p class="text-2xl font-semibold text-bon-blue"><span data-counter="38">0</span>%</p>
							<p class="mt-1 text-xs font-medium text-bon-950/55">Retencion objetivo</p>
						</div>
						<div class="rounded-[8px] bg-white/76 p-4 shadow-sm ring-1 ring-bon-line/80">
							<p class="text-2xl font-semibold text-bon-pink"><span data-counter="4">0</span>x</p>
							<p class="mt-1 text-xs font-medium text-bon-950/55">Tests por semana</p>
						</div>
						<div class="rounded-[8px] bg-white/76 p-4 shadow-sm ring-1 ring-bon-line/80">
							<p class="text-2xl font-semibold text-bon-lilac">24/7</p>
							<p class="mt-1 text-xs font-medium text-bon-950/55">Operacion activa</p>
						</div>
					</div>
				</div>

				<div class="relative" data-reveal>
					<div class="absolute -left-4 top-12 hidden h-28 w-28 rounded-full bg-bon-pink/18 blur-2xl sm:block"></div>
					<div class="absolute -right-6 bottom-8 hidden h-36 w-36 rounded-full bg-bon-sky/24 blur-2xl sm:block"></div>
					<div class="surface-line relative overflow-hidden rounded-[8px] bg-white p-3">
						<img
							class="h-[32rem] w-full rounded-[6px] object-cover object-center"
							src="/images/creator-studio.jpg"
							alt="Creadora trabajando en un estudio luminoso con ordenador portatil"
						/>
						<div class="absolute bottom-6 left-6 right-6 grid gap-3 sm:grid-cols-2">
							<div class="rounded-[8px] bg-white/92 p-4 shadow-xl backdrop-blur">
								<p class="text-xs font-semibold uppercase text-bon-blue">Traffic systems</p>
								<p class="mt-2 text-2xl font-semibold text-bon-950">Multi-channel</p>
							</div>
							<div class="rounded-[8px] bg-bon-950/92 p-4 text-white shadow-xl backdrop-blur">
								<p class="text-xs font-semibold uppercase text-bon-sky">Monetization</p>
								<p class="mt-2 text-2xl font-semibold">LTV first</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="sistema" class="bg-white px-5 py-24 sm:px-8">
			<div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.8fr_1.2fr]">
				<div data-reveal>
					<p class="text-sm font-semibold uppercase tracking-[0.18em] text-bon-pink">Sistema</p>
					<h2 class="mt-4 text-3xl font-semibold text-balance text-bon-950 sm:text-5xl">
						Una estructura pensada para creadoras, no una agencia que solo promete alcance.
					</h2>
				</div>
				<div class="grid gap-4 sm:grid-cols-3">
					{pillars.map((pillar) => (
						<article class="surface-line rounded-[8px] bg-bon-soft p-6" data-reveal>
							<p class="text-3xl font-semibold text-bon-blue">{pillar.value}</p>
							<h3 class="mt-6 text-xl font-semibold text-bon-950">{pillar.title}</h3>
							<p class="mt-4 leading-7 text-bon-950/62">{pillar.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section id="servicios" class="px-5 py-24 sm:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="max-w-3xl" data-reveal>
					<p class="text-sm font-semibold uppercase tracking-[0.18em] text-bon-blue">Servicios</p>
					<h2 class="mt-4 text-3xl font-semibold text-balance text-bon-950 sm:text-5xl">
						Todo lo que necesita una creadora para pasar de improvisar a operar con estrategia.
					</h2>
				</div>
				<div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
					{services.map((service) => (
						<article class="surface-line rounded-[8px] bg-white p-6 transition hover:-translate-y-1 hover:border-bon-blue/30 hover:shadow-xl" data-reveal>
							<p class="text-xs font-bold uppercase tracking-[0.18em] text-bon-pink">{service.kicker}</p>
							<h3 class="mt-5 text-xl font-semibold text-bon-950">{service.title}</h3>
							<p class="mt-4 leading-7 text-bon-950/62">{service.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section id="proceso" class="bg-white px-5 py-24 sm:px-8">
			<div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.95fr_1.05fr]">
				<div data-reveal>
					<p class="text-sm font-semibold uppercase tracking-[0.18em] text-bon-lilac">Proceso</p>
					<h2 class="mt-4 text-3xl font-semibold text-balance text-bon-950 sm:text-5xl">
						De marca dispersa a sistema de crecimiento con foco comercial.
					</h2>
					<p class="mt-6 text-lg leading-8 text-bon-950/64">
						El scroll debe sentirse ligero, claro y aspiracional. La pagina va guiando a la creadora desde su problema actual hasta una solucion concreta y ejecutable.
					</p>
				</div>
				<div class="space-y-4">
					{steps.map((step, index) => (
						<div class="surface-line flex gap-5 rounded-[8px] bg-bon-soft p-5" data-reveal>
							<span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-bon-blue text-sm font-semibold text-white">
								{String(index + 1).padStart(2, '0')}
							</span>
							<p class="pt-2 leading-7 text-bon-950/70">{step}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section id="aplicar" class="px-5 py-24 sm:px-8">
			<div class="surface-line mx-auto grid max-w-7xl gap-8 rounded-[8px] bg-bon-blue p-6 text-white sm:p-10 lg:grid-cols-[1fr_auto] lg:items-center">
				<div data-reveal>
					<p class="text-sm font-semibold uppercase tracking-[0.18em] text-white/72">Siguiente paso</p>
					<h2 class="mt-3 max-w-3xl text-3xl font-semibold text-balance sm:text-5xl">
						Ahora ya tenemos una direccion visual mas clara para presentar al cliente.
					</h2>
				</div>
				<a
					class="focus-ring inline-flex justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-bon-blue transition hover:bg-bon-pink hover:text-white"
					href="mailto:hello@bonmanagement.com"
					data-reveal
				>
					Contactar
				</a>
			</div>
		</section>
	</main>

	<script>
		import { gsap } from 'gsap';
		import { ScrollTrigger } from 'gsap/ScrollTrigger';

		gsap.registerPlugin(ScrollTrigger);

		const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		const animateCounter = (element: HTMLElement) => {
			const target = Number(element.dataset.counter ?? '0');
			const value = { current: 0 };

			gsap.to(value, {
				current: target,
				duration: 1.4,
				ease: 'power2.out',
				onUpdate: () => {
					element.textContent = Math.round(value.current).toString();
				},
			});
		};

		const initAnimations = () => {
			if (!reduceMotion) {
				gsap.utils.toArray('[data-reveal]').forEach((element) => {
					gsap.fromTo(
						element,
						{ autoAlpha: 0, y: 36 },
						{
							autoAlpha: 1,
							duration: 0.9,
							ease: 'power3.out',
							y: 0,
							scrollTrigger: {
								trigger: element,
								start: 'top 82%',
							},
						},
					);
				});

				ScrollTrigger.refresh();
			}

			gsap.utils.toArray('[data-counter]').forEach((element) => {
				const counter = element as HTMLElement;
				const target = Number((element as HTMLElement).dataset.counter ?? '0');

				if (reduceMotion) {
					counter.textContent = String(target);
					return;
				}

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								animateCounter(counter);
								observer.unobserve(counter);
							}
						});
					},
					{ threshold: 0.45 },
				);

				observer.observe(counter);
			});
		};

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initAnimations, { once: true });
		} else {
			initAnimations();
		}
	</script>
</BaseLayout>
