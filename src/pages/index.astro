---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header';
import ServiceCard from '../components/ServiceCard';
import PillarCard from '../components/PillarCard';
import ProcessStep from '../components/ProcessStep';
import CtaSection from '../components/CtaSection';

const services = [
	{
		icon: 'traffic' as const,
		kicker: 'Traffic',
		title: 'Marketing en redes sociales',
		text: 'Contenido, calendario y distribucion en plataformas clave para atraer una audiencia que ya llega preparada para convertir.',
	},
	{
		icon: 'strategy' as const,
		kicker: 'Strategy',
		title: 'Optimizacion de estrategia',
		text: 'Revision de precios, embudos, PPV, retencion y comportamiento de fans para mejorar ingresos con datos reales.',
	},
	{
		icon: 'brand' as const,
		kicker: 'Brand',
		title: 'Desarrollo de branding',
		text: 'Posicionamiento, tono, imagen y narrativa para que la creadora tenga una marca reconocible, deseable y consistente.',
	},
	{
		icon: 'scale' as const,
		kicker: 'Scale',
		title: 'Sistemas de escalado',
		text: 'Testing de hooks, lectura de senales, expansion multi-cuenta y rutinas semanales para multiplicar lo que funciona.',
	},
	{
		icon: 'chat' as const,
		kicker: 'Chat',
		title: 'Chatting en OnlyFans',
		text: 'Conversaciones, upsells, renovaciones y retencion gestionadas con protocolos que protegen la marca personal.',
	},
	{
		icon: 'ops' as const,
		kicker: 'Ops',
		title: 'Management integral',
		text: 'Planificacion, reporting, equipo operativo y seguimiento de KPIs para que la creadora pueda centrarse en crear.',
	},
];

const pillars = [
	{
		value: '01',
		title: 'Marca con criterio',
		text: 'La creadora no se ve como una cuenta mas. Tiene una identidad clara, premium y facil de reconocer.',
		accent: 'blue' as const,
	},
	{
		value: '02',
		title: 'Crecimiento medible',
		text: 'Cada decision se conecta con trafico, conversion, retencion y valor del fan, no con intuiciones sueltas.',
		accent: 'pink' as const,
	},
	{
		value: '03',
		title: 'Operacion diaria',
		text: 'Marketing, chatting y reporting trabajan coordinados para que el negocio avance todos los dias.',
		accent: 'lilac' as const,
	},
];

const steps = [
	'Auditoria inicial de marca, contenido, trafico y monetizacion actual.',
	'Direccion visual, definicion de oferta, precios y calendario de crecimiento.',
	'Ejecucion de marketing, chatting, optimizacion continua y reporting semanal.',
	'Escalado con pruebas semanales y decisiones estrategicas basadas en datos.',
];
---

<BaseLayout>
	<Header client:load />

	<main class="overflow-hidden">
		<!-- Hero Section -->
		<section id="inicio" class="soft-grid relative min-h-screen px-5 pb-24 pt-28 sm:px-8 lg:pt-32">
			<!-- Decorative blurs - hidden on mobile for performance -->
			<div class="pointer-events-none absolute left-[5%] top-[10%] hidden h-96 w-96 rounded-full bg-bon-sky/15 blur-[100px] md:block"></div>
			<div class="pointer-events-none absolute right-[10%] top-[20%] hidden h-80 w-80 rounded-full bg-bon-pink/10 blur-[80px] md:block"></div>
			<div class="pointer-events-none absolute bottom-[20%] left-[40%] hidden h-64 w-64 rounded-full bg-bon-lilac/8 blur-[60px] md:block"></div>

			<div class="relative mx-auto grid max-w-7xl items-center gap-14 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16">
				<div data-reveal>
					<div class="mb-6 inline-flex items-center gap-2 rounded-full border border-bon-blue/15 bg-white/80 px-5 py-2.5 shadow-sm">
						<span class="h-2 w-2 animate-pulse rounded-full bg-bon-blue"></span>
						<span class="text-sm font-medium text-bon-950/70">OnlyFans Management para creadoras que quieren crecer en serio</span>
					</div>

					<h1 class="max-w-2xl text-balance text-4xl font-semibold leading-[1.08] tracking-tight text-bon-950 sm:text-5xl lg:text-6xl xl:text-7xl">
						Convierte tu marca personal en un
						<span class="bg-gradient-to-r from-bon-blue via-bon-sky to-bon-blue bg-clip-text text-transparent">negocio escalable</span>
					</h1>

					<p class="mt-7 max-w-xl text-lg leading-relaxed text-bon-950/65 sm:text-xl">
						Marketing, branding, viralidad, chatting y management coordinados para que puedas crecer en OnlyFans con una estructura profesional detras de tu contenido.
					</p>

					<div class="mt-10 flex flex-col gap-4 sm:flex-row">
						<a
							class="focus-ring group inline-flex items-center justify-center gap-2 rounded-full bg-gradient-to-r from-bon-blue to-bon-blue px-8 py-4 text-sm font-semibold text-white shadow-xl shadow-bon-blue/25 transition-all duration-300 hover:gap-3 hover:from-bon-pink hover:to-bon-coral hover:shadow-bon-pink/25"
							href="#aplicar"
						>
							Solicitar auditoria
							<svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
							</svg>
						</a>
						<a
							class="focus-ring rounded-full border border-bon-line bg-white/80 px-8 py-4 text-center text-sm font-semibold text-bon-950 backdrop-blur transition-all duration-300 hover:border-bon-blue/30 hover:bg-white hover:text-bon-blue hover:shadow-lg"
							href="#servicios"
						>
							Ver servicios
						</a>
					</div>

					<!-- Stats -->
					<div class="mt-14 grid max-w-lg grid-cols-3 gap-4">
						<div class="group rounded-2xl bg-white/90 p-5 shadow-sm ring-1 ring-bon-line/60 transition-all duration-300 hover:bg-white hover:shadow-md">
							<p class="text-3xl font-bold text-bon-blue">
								+<span data-counter="38">0</span>%
							</p>
							<p class="mt-2 text-xs font-medium text-bon-950/50">Retencion objetivo</p>
						</div>
						<div class="group rounded-2xl bg-white/90 p-5 shadow-sm ring-1 ring-bon-line/60 transition-all duration-300 hover:bg-white hover:shadow-md">
							<p class="text-3xl font-bold text-bon-pink">
								<span data-counter="4">0</span>x
							</p>
							<p class="mt-2 text-xs font-medium text-bon-950/50">Tests semanales</p>
						</div>
						<div class="group rounded-2xl bg-white/90 p-5 shadow-sm ring-1 ring-bon-line/60 transition-all duration-300 hover:bg-white hover:shadow-md">
							<p class="text-3xl font-bold text-bon-lilac">24/7</p>
							<p class="mt-2 text-xs font-medium text-bon-950/50">Operacion activa</p>
						</div>
					</div>
				</div>

				<!-- Hero Visual -->
				<div class="relative" data-reveal>
					<!-- Floating decorative elements - hidden on mobile -->
					<div class="pointer-events-none absolute -left-6 top-8 hidden h-24 w-24 rounded-full bg-bon-pink/20 blur-2xl md:block"></div>
					<div class="pointer-events-none absolute -right-8 bottom-12 hidden h-32 w-32 rounded-full bg-bon-sky/25 blur-2xl md:block"></div>

					<div class="surface-line relative overflow-hidden rounded-3xl bg-white p-3 sm:p-4">
						<img
							class="h-[28rem] w-full rounded-2xl object-cover object-center sm:h-[34rem]"
							src="/images/creator-studio.jpg"
							alt="Creadora de contenido trabajando en un estudio luminoso con su ordenador"
						/>

						<!-- Floating cards -->
						<div class="absolute bottom-8 left-4 right-4 grid gap-3 sm:bottom-10 sm:left-8 sm:right-8 sm:grid-cols-2">
							<div class="rounded-2xl bg-white/95 p-5 shadow-2xl backdrop-blur-sm">
								<div class="flex items-center gap-3">
									<div class="flex h-10 w-10 items-center justify-center rounded-xl bg-bon-blue/10">
										<svg class="h-5 w-5 text-bon-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
										</svg>
									</div>
									<div>
										<p class="text-[10px] font-bold uppercase tracking-wider text-bon-blue">Traffic systems</p>
										<p class="text-lg font-semibold text-bon-950">Multi-channel</p>
									</div>
								</div>
							</div>
							<div class="rounded-2xl bg-bon-950/95 p-5 text-white shadow-2xl backdrop-blur-sm">
								<div class="flex items-center gap-3">
									<div class="flex h-10 w-10 items-center justify-center rounded-xl bg-bon-sky/20">
										<svg class="h-5 w-5 text-bon-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
										</svg>
									</div>
									<div>
										<p class="text-[10px] font-bold uppercase tracking-wider text-bon-sky">Monetization</p>
										<p class="text-lg font-semibold">LTV first</p>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Sistema Section -->
		<section id="sistema" class="bg-white px-5 py-28 sm:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:items-start lg:gap-16">
					<div class="lg:sticky lg:top-32" data-reveal>
						<p class="inline-flex rounded-full bg-bon-pink/10 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-bon-pink">
							Sistema
						</p>
						<h2 class="mt-6 text-balance text-3xl font-semibold leading-tight text-bon-950 sm:text-4xl lg:text-5xl">
							Una estructura pensada para creadoras, no una agencia que solo promete alcance.
						</h2>
						<p class="mt-6 text-lg leading-relaxed text-bon-950/60">
							Combinamos branding, marketing, operaciones y datos en un sistema integrado que trabaja para ti las 24 horas.
						</p>
					</div>

					<div class="grid gap-5 sm:grid-cols-3">
						{pillars.map((pillar) => (
							<PillarCard {...pillar} client:visible />
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Servicios Section -->
		<section id="servicios" class="px-5 py-28 sm:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="max-w-3xl" data-reveal>
					<p class="inline-flex rounded-full bg-bon-blue/10 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-bon-blue">
						Servicios
					</p>
					<h2 class="mt-6 text-balance text-3xl font-semibold leading-tight text-bon-950 sm:text-4xl lg:text-5xl">
						Todo lo que necesita una creadora para pasar de improvisar a operar con estrategia.
					</h2>
					<p class="mt-6 max-w-2xl text-lg leading-relaxed text-bon-950/60">
						Cada servicio esta disenado para integrarse con los demas y crear un ecosistema de crecimiento coherente.
					</p>
				</div>

				<div class="mt-14 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
					{services.map((service) => (
						<ServiceCard {...service} client:visible />
					))}
				</div>
			</div>
		</section>

		<!-- Proceso Section -->
		<section id="proceso" class="bg-white px-5 py-28 sm:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="grid gap-12 lg:grid-cols-[1fr_1.1fr] lg:items-start lg:gap-20">
					<div class="lg:sticky lg:top-32" data-reveal>
						<p class="inline-flex rounded-full bg-bon-lilac/10 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-bon-lilac">
							Proceso
						</p>
						<h2 class="mt-6 text-balance text-3xl font-semibold leading-tight text-bon-950 sm:text-4xl lg:text-5xl">
							De marca dispersa a sistema de crecimiento con foco comercial.
						</h2>
						<p class="mt-6 text-lg leading-relaxed text-bon-950/60">
							El proceso guia a la creadora desde su situacion actual hasta una estructura escalable y rentable en cuatro fases claras.
						</p>

						<div class="mt-10 flex items-center gap-4">
							<div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-bon-blue to-bon-sky text-white shadow-lg shadow-bon-blue/20">
								<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
							</div>
							<div>
								<p class="text-sm font-medium text-bon-950/50">Duracion estimada</p>
								<p class="text-xl font-semibold text-bon-950">4-8 semanas</p>
							</div>
						</div>
					</div>

					<div class="space-y-4">
						{steps.map((step, index) => (
							<ProcessStep number={index + 1} text={step} client:visible />
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<CtaSection client:visible />

		<!-- Footer -->
		<footer class="border-t border-bon-line/60 bg-white px-5 py-12 sm:px-8">
			<div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-6 sm:flex-row">
				<a class="text-lg font-bold tracking-[0.18em] text-bon-950" href="#inicio">
					BON
				</a>
				<p class="text-sm text-bon-950/50">
					&copy; {new Date().getFullYear()} BON Management. Todos los derechos reservados.
				</p>
			</div>
		</footer>
	</main>

	<script>
		import { gsap } from 'gsap';
		import { ScrollTrigger } from 'gsap/ScrollTrigger';

		gsap.registerPlugin(ScrollTrigger);

		const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const isMobile = window.innerWidth < 768;

		const animateCounter = (element: HTMLElement) => {
			const target = Number(element.dataset.counter ?? '0');
			const value = { current: 0 };

			gsap.to(value, {
				current: target,
				duration: 1.6,
				ease: 'power3.out',
				onUpdate: () => {
					element.textContent = Math.round(value.current).toString();
				},
			});
		};

		const initAnimations = () => {
			// Set initial visibility for reveal elements
			const allReveals = document.querySelectorAll('[data-reveal]');

			if (!reduceMotion) {
				// Set initial state
				gsap.set(allReveals, { autoAlpha: 0, y: isMobile ? 30 : 48 });

				// Staggered reveal animations
				const sections = document.querySelectorAll('section');

				sections.forEach((section) => {
					const reveals = section.querySelectorAll('[data-reveal]');
					if (reveals.length === 0) return;

					gsap.to(reveals, {
						autoAlpha: 1,
						duration: isMobile ? 0.6 : 0.9,
						ease: 'power2.out',
						stagger: isMobile ? 0.08 : 0.12,
						y: 0,
						scrollTrigger: {
							trigger: section,
							start: isMobile ? 'top 85%' : 'top 78%',
							once: true,
						},
					});
				});

				// Refresh after a short delay to ensure DOM is ready
				requestAnimationFrame(() => {
					ScrollTrigger.refresh();
				});
			} else {
				// If reduced motion, just show everything
				gsap.set(allReveals, { autoAlpha: 1, y: 0 });
			}

			// Counter animations
			gsap.utils.toArray('[data-counter]').forEach((element) => {
				const counter = element as HTMLElement;
				const target = Number(counter.dataset.counter ?? '0');

				if (reduceMotion) {
					counter.textContent = String(target);
					return;
				}

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								animateCounter(counter);
								observer.unobserve(counter);
							}
						});
					},
					{ threshold: 0.5 },
				);

				observer.observe(counter);
			});
		};

		// Wait for everything to be ready
		const start = () => {
			// Small delay to ensure Astro hydration is complete
			setTimeout(initAnimations, 100);
		};

		if (document.readyState === 'complete') {
			start();
		} else {
			window.addEventListener('load', start, { once: true });
		}
	</script>
</BaseLayout>
